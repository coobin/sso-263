PORT=3000
APP_BASE_URL=https://mail.example.com

# Auth mode:
# - trusted_headers: recommended for Authelia + Nginx Proxy Manager
# - exchange_code: use a custom auth backend that returns user info from a one-time code
AUTH_MODE=trusted_headers

# Only used when AUTH_MODE=exchange_code
AUTH_LOGIN_URL=https://auth.example.com/login
AUTH_EXCHANGE_URL=https://auth.example.com/api/sso/exchange-code
AUTH_EXCHANGE_TOKEN=

# Only used when AUTH_MODE=trusted_headers
REMOTE_USER_HEADER=Remote-User
REMOTE_EMAIL_HEADER=Remote-Email
REMOTE_NAME_HEADER=Remote-Name

# Cookie settings
MAIL_COOKIE_NAME=mail_sso_session
COOKIE_SECURE=true
COOKIE_DOMAIN=mail.example.com
SESSION_SECRET=replace-with-a-long-random-string
SESSION_TTL_SECONDS=3600

# 263 settings
PARTNER_ID=100439
AUTH_CORP_ID=example.com
API_SECRET=replace-with-263-secret
MAIL_SSO_BASE_URL=https://weixin.263.net/partner/web/third/mail/loginMail.do

# Optional timeout for the auth code exchange request
AUTH_EXCHANGE_TIMEOUT_MS=5000

# Audit logs are written as one JSON object per line to stdout
AUDIT_LOG_ENABLED=true
